# ── REQUIRED ─────────────────────────────────────────────────────────────────

# Google Gemini API key (https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=your-google-api-key

# NewsData.io API key (https://newsdata.io/ — free tier available)
NEWSDATA_API_KEY=your-newsdata-api-key


# Microsoft Bing Image Creator — free with a Microsoft account
# 1. Go to https://www.bing.com/images/create and log in
# 2. Open DevTools (F12) → Application → Cookies → bing.com
# 3. Copy the value of the "_U" cookie
BING_AUTH_COOKIE=


# ── OPTIONAL: Social Media Credentials ───────────────────────────────────────
# Leave blank to run in simulation mode (posts are logged but not published)

# X (Twitter) — Developer Portal: https://developer.twitter.com/
X_BEARER_TOKEN=
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# Facebook Page — Meta for Developers: https://developers.facebook.com/
# Requires a Facebook App with "pages_manage_posts" permission
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_TOKEN=

# Instagram Business Account — uses the same Facebook Page token above
# Find your Instagram Business Account ID in Meta Business Suite
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# LinkedIn — LinkedIn Developer Portal: https://www.linkedin.com/developers/
# Requires "w_member_social" or "w_organization_social" OAuth scope
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=urn:li:person:YOUR_PERSON_ID
# For a company page use: urn:li:organization:YOUR_ORG_ID
